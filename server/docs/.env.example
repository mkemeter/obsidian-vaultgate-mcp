# Environment variables for obsidian-vaultgate-mcp
# Copy this file to .env and fill in your values, or set these in your
# assistant's MCP configuration (recommended for Claude Code and HTTP clients).

# Vault name to target. When set, every CLI command is scoped to this vault.
# Omit if you only have a single vault (the CLI uses the last focused vault).
OBSIDIAN_VAULT=

# Absolute path to the obsidian CLI binary.
# Leave blank when the CLI is on your PATH (default after "Register CLI" in Obsidian).
# Must be set to an absolute path when running under launchd (macOS auto-start),
# because launchd does not inherit your shell's PATH.
# Example: /Applications/Obsidian.app/Contents/MacOS/obsidian
OBSIDIAN_CLI_PATH=

# TCP port the HTTP server listens on. Defaults to 3001.
# Change this if port 3001 is already in use on your machine.
OBSIDIAN_MCP_PORT=3001

# Transport mode override. Leave unset for automatic detection (recommended).
# stdio  — always use stdio, even when stdin is a TTY
# http   — always start the HTTP server (useful for launchd / background services)
OBSIDIAN_MCP_TRANSPORT=
