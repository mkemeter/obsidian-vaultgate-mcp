{
  "name": "vaultgate",
  "version": "0.1.0",
  "private": true,
  "description": "VaultGate tray companion — runs the obsidian-vaultgate-mcp server with a menu-bar UI.",
  "main": "dist/main.js",
  "scripts": {
    "build:server": "cd ../server && npm run build",
    "bundle:server": "esbuild ../server/build/index.js --bundle --platform=node --format=esm --outfile=dist/server/server.mjs --external:onnxruntime-node --external:sharp",
    "build:tray": "tsc",
    "build:renderer": "node scripts/copy-renderer.js",
    "download-models": "node scripts/download-models.js",
    "build": "npm run build:server && npm run bundle:server && npm run build:tray && npm run build:renderer",
    "package": "npm run build && electron-builder",
    "dev": "npm run build && electron .",
    "rebuild": "electron-rebuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
