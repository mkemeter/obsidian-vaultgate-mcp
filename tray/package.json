{
  "name": "vaultgate",
  "version": "0.1.0",
  "private": true,
  "description": "VaultGate tray companion — runs the obsidian-vaultgate-mcp server with a menu-bar UI.",
  "author": "Mathias Kemeter",
  "repository": {
    "type": "git",
    "url": "https://github.com/mkemeter/obsidian-vaultgate-mcp.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "build:server": "cd ../server && npm run build",
    "bundle:server": "node scripts/copy-server-build.js",
    "bundle:deps": "node scripts/copy-server-deps.js",
    "build:tray": "tsc",
    "build:renderer": "node scripts/copy-renderer.js",
    "download-models": "node scripts/download-models.js",
    "generate-icons": "node scripts/generate-icons.js",
    "build": "npm run build:server && npm run bundle:server && npm run bundle:deps && npm run build:tray && npm run build:renderer",
    "package": "npm run build && electron-builder",
    "dev": "npm run build && electron .",
    "rebuild": "electron-rebuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@xenova/transformers": "^2.17.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.28.1",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
